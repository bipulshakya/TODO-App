# Database
# Primary DB mode: local or cloud (default local when DB_HOST exists)
DB_PRIMARY=local

# Local DB settings
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=todo_app
DB_PORT=3306
# Set true only if your local MySQL requires SSL
DB_SSL=false

# Cloud DB connection string
# DATABASE_URL=mysql://user:password@host:3306/todo_app

# Optional: mirror write operations to a second DB
# DB_MIRROR_ENABLED=true
# DB_MIRROR_URL=mysql://user:password@host:3306/todo_app

# Server
PORT=5001

# Auth
JWT_SECRET=your_super_secret_key_here
